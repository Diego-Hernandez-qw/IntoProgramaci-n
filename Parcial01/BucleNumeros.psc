Algoritmo BucleNumeros
	//4.	Crear un programa que reciba un número N y muestre los primeros N números pares usando un bucle para. ( modulo Para ) 
	
	Definir N, i, par Como Entero
    
    Escribir "Ingrese la cantidad de números pares que desea ver:"
    Leer N
    
    Escribir "Los primeros ", N, " números pares son:"
    
    // El bucle se ejecutará exactamente N veces
    Para i <- 1 Hasta N Con Paso 1 Hacer
        par <- i * 2
        Escribir par
    FinPara
	
	
	
	
FinAlgoritmo
